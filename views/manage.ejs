<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="css/bootstrap.min.css" />
    <script src="js/jquery-3.4.1.slim.min.js"></script>
    <script src="js/popper.min.js"></script>
    <script src="js/bootstrap.min.js"></script>
    <link rel="stylesheet" href="css/all.css" />
    <style>
        .low-stock { background-color: #fff3f3; color: #dc3545; font-weight: bold; }
        .badge-stock { padding: 5px 10px; border-radius: 20px; }
    </style>
</head>
<body>
    <%- include('navbar.ejs') %>
    
    <div class="container mt-4">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
                <h2 class="font-weight-bold">📦 จัดการสต็อกสินค้า</h2>
                <p class="text-muted">ตรวจสอบจำนวนคงเหลือและแก้ไขข้อมูลสินค้า</p>
            </div>
            <a href="/addForm" class="btn btn-success rounded-pill px-4 shadow-sm">+ เพิ่มสินค้าใหม่</a>
        </div>

        <input type="text" id="searchInput" class="form-control mb-3 shadow-sm" placeholder="🔍 ค้นหาชื่อสินค้า, ราคา หรือรายละเอียด...">

        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover bg-white mb-0">
                <thead class="thead-light">
                    <tr>
                        <th>ชื่อสินค้า</th>
                        <th class="text-right">ต้นทุน</th>
                        <th class="text-right">ราคาขาย</th>
                        <th class="text-center">คงเหลือ (Stock)</th>
                        <th>รูปภาพ</th>
                        <th class="text-center">จัดการ</th>
                    </tr>
                </thead>

                <tbody id="productTable">
                    <% Object.values(products).forEach(function(item){ %>
                    <tr class="<%= (item.stock <= 5) ? 'low-stock' : '' %>">
                        <td class="name font-weight-bold"><%= item.name %></td>
                        <td class="text-right text-muted"><%= (item.cost || 0).toLocaleString() %> ฿</td>
                        <td class="price text-right font-weight-bold text-primary"><%= (item.price || 0).toLocaleString() %> ฿</td>
                        <td class="text-center">
                            <span class="badge badge-stock <%= (item.stock <= 5) ? 'badge-danger' : 'badge-info' %>">
                                <%= item.stock || 0 %> ชิ้น
                            </span>
                            <% if(item.stock <= 5) { %>
                                <br><small class="text-danger">⚠️ ของใกล้หมด</small>
                            <% } %>
                        </td>
                        <td>
                            <img class="img-thumbnail" src="./images/products/<%= item.image %>" alt="<%= item.name %>"
                                style="width: 50px; height: 50px; object-fit: cover;">
                        </td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center">
                                <form action="/edit" method="POST" class="mr-1">
                                    <input type="hidden" value="<%= item._id %>" name="id">
                                    <button type="submit" class="btn btn-sm btn-outline-primary"><i class="fas fa-edit"></i> แก้ไข</button>
                                </form>
                                <a class="btn btn-sm btn-outline-danger" href="/delete/<%= item._id %>" onclick="return confirm('คุณต้องการลบ [<%= item.name %>] ใช่หรือไม่?')">
                                    <i class="fas fa-trash"></i> ลบ
                                </a>
                            </div>
                        </td>
                    </tr>
                    <% }) %>                    
                </tbody>
            </table>
        </div>

        <script>
            document.getElementById("searchInput").addEventListener("keyup", function () {
                let filter = this.value.toLowerCase();
                let rows = document.querySelectorAll("#productTable tr");

                rows.forEach(row => {
                    let text = row.innerText.toLowerCase();
                    row.style.display = text.includes(filter) ? "" : "none";
                });
            });
        </script>
    </div>
</body>
</html>