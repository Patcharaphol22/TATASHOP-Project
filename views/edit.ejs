<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;700&display=swap" rel="stylesheet">
<style>
    body {
        background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
        min-height: 100vh;
    }
    .edit-card {
        border: none;
        border-radius: 20px;
        overflow: hidden;
    }
    .card-header-custom {
        background: white;
        border-bottom: 1px solid #eee;
        padding: 25px;
    }
    .form-label {
        font-weight: 600;
        color: #555;
        font-size: 0.9rem;
        margin-bottom: 8px;
        display: block;
    }
    .form-control {
        border-radius: 12px;
        padding: 12px 15px;
        border: 1px solid #e1e5ea;
        transition: all 0.3s ease;
    }
    .form-control:focus {
        box-shadow: 0 0 0 4px rgba(0, 123, 255, 0.1);
        border-color: #007bff;
    }
    .input-group-text {
        background: #f8f9fa;
        border-radius: 12px 0 0 12px !important;
        border-right: none;
    }
    .has-icon .form-control {
        border-radius: 0 12px 12px 0 !important;
    }
    .current-img-container {
        position: relative;
        display: inline-block;
    }
    .current-img {
        border-radius: 15px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        transition: transform 0.3s;
    }
    .current-img:hover {
        transform: scale(1.05);
    }
    .btn-save {
        background: #007bff;
        border: none;
        border-radius: 12px;
        padding: 12px;
        font-weight: bold;
        transition: all 0.3s;
    }
    .btn-save:hover {
        background: #0056b3;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0,123,255,0.3);
    }
    .btn-cancel {
        border-radius: 12px;
        padding: 12px;
        color: #777;
    }
</style>

<%- include('navbar.ejs') %>

<div class="container py-5">
    <div class="card edit-card shadow-lg mx-auto" style="max-width: 650px;">
        <div class="card-header-custom text-center">
            <div class="mb-2">
                <i class="fas fa-box-open text-primary fa-3x"></i>
            </div>
            <h3 class="font-weight-bold text-dark mb-1">แก้ไขข้อมูลสินค้า</h3>
            <p class="text-muted small">รหัสอ้างอิง: <span class="badge badge-light">#<%= item._id %></span></p>
        </div>

        <div class="card-body p-4 p-md-5 bg-white">
            <form action="/update" method="POST" enctype="multipart/form-data">
                <input type="hidden" name="id" value="<%= item._id %>">

                <div class="form-group mb-4">
                    <label class="form-label"><i class="fas fa-tag mr-2 text-muted"></i>ชื่อสินค้า</label>
                    <input type="text" name="name" class="form-control" value="<%= item.name %>" placeholder="ระบุชื่อสินค้า..." required>
                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-4">
                            <label class="form-label"><i class="fas fa-hand-holding-usd mr-2 text-muted"></i>ต้นทุน (Cost)</label>
                            <div class="input-group has-icon">
                                <div class="input-group-prepend">
                                    <span class="input-group-text text-danger">฿</span>
                                </div>
                                <input type="number" name="cost" class="form-control font-weight-bold" value="<%= item.cost || 0 %>" required>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group mb-4">
                            <label class="form-label"><i class="fas fa-comment-dollar mr-2 text-muted"></i>ราคาขาย (Price)</label>
                            <div class="input-group has-icon">
                                <div class="input-group-prepend">
                                    <span class="input-group-text text-success">฿</span>
                                </div>
                                <input type="number" name="price" class="form-control font-weight-bold text-primary" value="<%= item.price %>" required>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-group mb-4">
                    <label class="form-label"><i class="fas fa-layer-group mr-2 text-muted"></i>จำนวนในสต็อก (Stock)</label>
                    <input type="number" name="stock" class="form-control" value="<%= item.stock || 0 %>" placeholder="0" required>
                </div>

                <div class="form-group mb-4">
                    <label class="form-label"><i class="fas fa-align-left mr-2 text-muted"></i>รายละเอียดสินค้า</label>
                    <textarea name="description" class="form-control" rows="4" placeholder="ระบุรายละเอียดเพิ่มเติม..."><%= item.description %></textarea>
                </div>

                <div class="form-group mb-5">
                    <label class="form-label"><i class="fas fa-image mr-2 text-muted"></i>รูปภาพสินค้า</label>
                    <div class="d-flex align-items-center p-3 border rounded" style="background: #fafafa;">
                        <div class="current-img-container mr-3 text-center">
                            <small class="text-muted d-block mb-1">รูปปัจจุบัน</small>
                            <img src="/images/products/<%= item.image %>" width="80" height="80" class="current-img style-object-fit: cover;">
                        </div>
                        <div class="flex-grow-1">
                            <input type="file" name="image" class="form-control-file border-0">
                            <small class="text-muted mt-2 d-block">* ปล่อยว่างไว้หากไม่ต้องการเปลี่ยนรูปภาพ</small>
                        </div>
                    </div>
                </div>

                <div class="form-row mt-4">
                    <div class="col-8">
                        <button type="submit" class="btn btn-primary btn-block btn-save shadow">
                            <i class="fas fa-check-circle mr-2"></i>บันทึกการแก้ไข
                        </button>
                    </div>
                    <div class="col-4">
                        <a href="/manage" class="btn btn-light btn-block btn-cancel">
                            ยกเลิก
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>