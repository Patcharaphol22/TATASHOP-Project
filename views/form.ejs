<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title><%= title %></title>
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
        <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.min.js"></script>
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    </head>
    <body>
        <%- include('navbar.ejs') %>        
        <div class="container mt-5">
            <div class="row justify-content-center">
              
                <div class="col-md-8 mb-4">
                    <div class="card shadow-sm p-4" style="border-radius: 15px;">
                        <h3 class="mb-4 font-weight-bold text-primary"><i class="fas fa-box-open mr-2"></i>เพิ่มสินค้าใหม่</h3>
                        <hr>
                        
                        <form class="form-horizontal" method="POST" action="/insert" enctype="multipart/form-data">

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label font-weight-bold">ชื่อสินค้า</label>
                                <div class="col-sm-9">
                                    <input type="text" class="form-control" name="name" placeholder="ระบุชื่อสินค้า" required>
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label font-weight-bold">ราคา (บาท)</label>
                                <div class="col-sm-9">
                                    <input type="number" class="form-control" name="price" placeholder="0.00" required>
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label font-weight-bold text-danger">จำนวนในสต็อก</label>
                                <div class="col-sm-9">
                                    <input type="number" class="form-control" name="stock" placeholder="เช่น 10, 50, 100" min="0" required>
                                    <small class="text-muted text-italic">* ข้อมูลนี้จะไปแสดงในหน้า Dashboard เมื่อสินค้าใกล้หมด</small>
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label font-weight-bold">ภาพสินค้า</label>
                                <div class="col-sm-9">
                                    <div class="custom-file">
                                        <input type="file" class="custom-file-input" name="image" id="customFile">
                                        <label class="custom-file-label" for="customFile">เลือกไฟล์ภาพ...</label>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group row">
                                <label class="col-sm-3 col-form-label font-weight-bold">รายละเอียด</label>
                                <div class="col-sm-9">
                                    <textarea class="form-control" cols="30" rows="4" name="description" placeholder="ระบุรายละเอียดสินค้าสั้นๆ..."></textarea>
                                </div>
                            </div>

                            <hr>
                            <div class="form-group row">
                                <div class="col-sm-12 text-right">
                                    <a href="/manage" class="btn btn-secondary px-4 mr-2" style="border-radius: 20px;">ยกเลิก</a>
                                    <button type="submit" class="btn btn-primary px-5 shadow-sm" style="border-radius: 20px;">
                                        <i class="fas fa-save mr-2"></i>บันทึกสินค้า
                                    </button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <script>
            // โค้ดแสดงชื่อไฟล์ที่เลือกในช่อง Custom File ของ Bootstrap
            $(".custom-file-input").on("change", function() {
              var fileName = $(this).val().split("\\").pop();
              $(this).siblings(".custom-file-label").addClass("selected").html(fileName);
            });
        </script>
    </body>
</html>