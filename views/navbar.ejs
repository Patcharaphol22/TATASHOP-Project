<style>
    .custom-navbar {
        background-color: #1a1d20 !important; /* สีเทาเข้มแบบ Tech Look */
        border-bottom: 2px solid #007AFF; /* เส้นขอบล่างสีฟ้า Electric Blue */
        transition: all 0.3s ease;
    }

    .nav-link {
        position: relative;
        transition: color 0.3s ease;
        font-size: 0.95rem;
        letter-spacing: 0.5px;
    }

    /* Effect เส้นใต้ตอน Hover */
    .nav-link::after {
        content: '';
        position: absolute;
        width: 0;
        height: 2px;
        bottom: 5px;
        left: 50%;
        background-color: #007AFF;
        transition: all 0.3s ease;
        transform: translateX(-50%);
    }

    .nav-link:hover::after {
        width: 70%;
    }

    .nav-link:hover {
        color: #007AFF !important;
    }

    .dropdown-menu {
        background-color: #24282d;
        border: 1px solid #3d444b;
        border-radius: 8px;
        box-shadow: 0 10px 15px rgba(0,0,0,0.3);
    }

    .dropdown-item {
        color: #e0e0e0;
        padding: 10px 20px;
        transition: all 0.2s;
    }

    .dropdown-item:hover {
        background-color: #007AFF;
        color: white;
    }

    .user-badge {
        background: rgba(0, 122, 255, 0.1);
        border: 1px solid #007AFF;
        border-radius: 20px;
        padding: 5px 15px;
    }
</style>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
<nav class="navbar navbar-expand-md navbar-dark custom-navbar shadow-lg sticky-top">
    <div class="container-fluid">
        <a href="/" class="navbar-brand">
            <img src="/images/home/image-Photoroom (1).png" alt="OWENSHOP" style="height: 45px; filter: drop-shadow(0 0 5px rgba(0,122,255,0.3));">
        </a>

        <button class="navbar-toggler border-0" type="button" data-toggle="collapse" data-target="#mainNavbar">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNavbar">
            <ul class="navbar-nav mr-auto">
                
                <% if (user) { %>
                <li class="nav-item">
                    <a class="nav-link text-info text-uppercase font-weight-bold px-3" href="/dashboard">
                        <i class="fas fa-chart-line mr-1"></i> แดชบอร์ด
                    </a>
                </li>
                <% } %>

                <li class="nav-item dropdown">
                    <a class="nav-link text-light text-uppercase font-weight-bold px-3 dropdown-toggle" href="#" data-toggle="dropdown">
                        <i class="fas fa-store-alt mr-1"></i> จัดการร้านค้า
                    </a>
                    <div class="dropdown-menu">
                        <a class="dropdown-item" href="/manage"><i class="fas fa-boxes mr-2"></i> จัดการสินค้า</a>
                        <a class="dropdown-item" href="/addForm"><i class="fas fa-plus-circle mr-2"></i> บันทึกสินค้าใหม่</a>
                        <div class="dropdown-divider" style="border-top: 1px solid #3d444b;"></div>
                        <a class="dropdown-item" href="/sales/new"><i class="fas fa-cash-register mr-2"></i> ขายสินค้า (POS)</a>
                        <a class="dropdown-item" href="/sales/report"><i class="fas fa-file-invoice-dollar mr-2"></i> รายงานการขาย</a>
                    </div>
                </li>

                <li class="nav-item dropdown">
                    <a class="nav-link text-light text-uppercase font-weight-bold px-3 dropdown-toggle" href="#" data-toggle="dropdown">
                        <i class="fas fa-users-cog mr-1"></i> ระบบบุคคล
                    </a>
                    <div class="dropdown-menu">
                        <a class="dropdown-item" href="/members"><i class="fas fa-user-friends mr-2"></i> รายชื่อสมาชิก</a>
                        <a class="dropdown-item" href="/employees"><i class="fas fa-user-tie mr-2"></i> รายชื่อพนักงาน</a>
                    </div>
                </li>
            </ul>

            <ul class="navbar-nav ml-auto align-items-center">
                <% if (user) { %>
                    <li class="nav-item mr-3">
                        <div class="user-badge">
                            <span class="text-light">
                                <i class="fas fa-user-circle text-info"></i> <%= user.name %> 
                                <span class="badge badge-info ml-1" style="font-size: 9px;"><%= user.role %></span>
                            </span>
                        </div>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-outline-danger btn-sm rounded-pill px-3" href="/logout">
                            <i class="fas fa-sign-out-alt"></i> ออกจากระบบ
                        </a>
                    </li>
                <% } else { %>
                    <li class="nav-item">
                        <a class="nav-link text-light font-weight-bold" href="/login">เข้าสู่ระบบ</a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-info btn-sm rounded-pill px-4 ml-2" href="/register">สมัครสมาชิก</a>
                    </li>
                <% } %>
            </ul>
        </div>
    </div>
</nav>