<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;700&display=swap" rel="stylesheet">

<style>
    body {
        font-family: 'Sarabun', sans-serif;
        background-color: #f0f2f5;
        color: #333;
    }
    .card { border-radius: 15px; overflow: hidden; transition: 0.3s; }
    .card-header { border-bottom: none; }
    .form-control-lg { border-radius: 10px; font-size: 1rem; }
    .btn-lg { border-radius: 10px; font-weight: bold; }
    .bg-danger-light { background-color: #fff5f5; }
    .custom-select { height: calc(1.5em + 1rem + 2px) !important; border-radius: 10px; }
    .total-box {
        background: #e9ecef;
        padding: 20px;
        border-radius: 12px;
        border-left: 5px solid #28a745;
    }
    nav { margin-bottom: 2rem; background: #fff; padding: 1rem; border-radius: 0 0 15px 15px; box-shadow: 0 2px 4px rgba(0,0,0,.05); }
</style>

<div class="container mt-4">
    <%- include('../navbar.ejs') %>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-success text-white py-3">
                    <h3 class="mb-0 text-center"><i class="fas fa-cash-register mr-2"></i> บันทึกการขาย (POS)</h3>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form action="/sales/insert" method="POST" id="posForm">
                        
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group mb-4">
                                    <label class="font-weight-bold text-secondary small text-uppercase">วันที่ทำรายการ</label>
                                    <input type="datetime-local" name="date" class="form-control form-control-lg" value="<%= new Date().toLocaleString('sv-SE').replace(' ', 'T').slice(0, 16) %>" required>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group mb-4">
                                    <label class="font-weight-bold text-secondary small text-uppercase">สมาชิก / ลูกค้า</label>
                                    <select name="member" class="form-control form-control-lg" required>
                                        <option value="" disabled selected>--- กรุณาเลือกลูกค้า ---</option>
                                        <% members.forEach(m => { %>
                                            <option value="<%= m._id %>"><%= m.name %> (<%= m.phone || 'ไม่ระบุเบอร์' %>)</option>
                                        <% }) %>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="form-group mb-4">
                            <label class="font-weight-bold text-secondary small text-uppercase">เลือกสินค้าในร้าน</label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text bg-white border-right-0"><i class="fas fa-tag text-success"></i></span>
                                </div>
                                <select name="product" id="productSelect" class="form-control form-control-lg border-left-0" required>
                                    <option value="" disabled selected>--- กรุณาเลือกสินค้า ---</option>
                                    <% products.forEach(p => { %>
                                        <option value="<%= p._id %>" data-price="<%= p.price %>">
                                            <%= p.name %> | ราคา <%= p.price.toLocaleString() %> ฿
                                        </option>
                                    <% }) %>
                                </select>
                            </div>
                        </div>

                        <div class="form-group mb-4">
                            <label class="font-weight-bold text-secondary small text-uppercase">รหัสคูปองส่วนลด</label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text bg-white border-right-0"><i class="fas fa-ticket-alt text-primary"></i></span>
                                </div>
                                <input type="text" id="couponCode" class="form-control form-control-lg border-left-0" placeholder="กรอกรหัสคูปอง (เช่น TATA10)">
                                <div class="input-group-append">
                                    <button class="btn btn-primary" type="button" id="applyCoupon">ใช้คูปอง</button>
                                </div>
                            </div>
                            <small id="couponStatus" class="form-text"></small>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group mb-4">
                                    <label class="font-weight-bold text-secondary small text-uppercase">จำนวน (หน่วย)</label>
                                    <div class="input-group">
                                        <input type="number" name="quantity" id="quantityInput" class="form-control form-control-lg text-center" value="1" min="0.01" step="0.01" required>
                                        <div class="input-group-append">
                                            <span class="input-group-text bg-white">ชิ้น</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="col-md-6">
                                <div class="form-group mb-4">
                                    <label class="font-weight-bold text-danger small text-uppercase">ส่วนลดพิเศษ (บาท)</label>
                                    <div class="input-group">
                                        <div class="input-group-prepend">
                                            <span class="input-group-text bg-danger-light text-danger border-right-0">฿</span>
                                        </div>
                                        <input type="number" name="discount" id="discountInput" class="form-control form-control-lg border-danger text-danger border-left-0" value="0" min="0" step="0.01">
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="form-group mb-4">
                            <label class="font-weight-bold text-secondary small text-uppercase">ช่องทางการชำระเงิน</label>
                            <select name="paymentMethod" class="form-control form-control-lg font-weight-bold text-primary">
                                <option value="Cash">💵 เงินสด (Cash)</option>
                                <option value="Transfer">🏦 โอนเงิน (Transfer)</option>
                                <option value="QR">📱 สแกนจ่าย (PromptPay)</option>
                            </select>
                        </div>

                        <div class="total-box mb-4 d-flex justify-content-between align-items-center">
                            <span class="h5 mb-0 text-muted">รวมทั้งสิ้น:</span>
                            <div>
                                <span id="totalDisplay" class="h1 font-weight-bold text-success">0.00</span>
                                <span class="h4 text-success"> ฿</span>
                            </div>
                        </div>

                        <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mt-5">
                            <a href="/sales/report" class="btn btn-link text-muted mb-3 mb-md-0"><i class="fas fa-history mr-1"></i> ดูประวัติการขาย</a>
                            <button type="submit" class="btn btn-success btn-lg px-5 shadow-sm w-100 w-md-auto">
                                <i class="fas fa-check-circle mr-2"></i> ยืนยันและพิมพ์ใบเสร็จ
                            </button>
                        </div>
                    </form>
                </div>
            </div>
            
            <p class="text-center text-muted mt-4"><small>© 2026 ITMI Shop Management System v2.0</small></p>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const productSelect = document.getElementById('productSelect');
        const quantityInput = document.getElementById('quantityInput');
        const discountInput = document.getElementById('discountInput');
        const totalDisplay = document.getElementById('totalDisplay');
        const couponCode = document.getElementById('couponCode');
        const applyCouponBtn = document.getElementById('applyCoupon');
        const couponStatus = document.getElementById('couponStatus');

        function calculateTotal() {
            const selectedOption = productSelect.options[productSelect.selectedIndex];
            const price = (selectedOption && selectedOption.dataset.price) ? parseFloat(selectedOption.dataset.price) : 0;
            
            const qty = parseFloat(quantityInput.value) || 0;
            const discount = parseFloat(discountInput.value) || 0;

            let total = (price * qty) - discount;
            if (total < 0) total = 0;

            totalDisplay.innerText = total.toLocaleString(undefined, {
                minimumFractionDigits: 2,
                maximumFractionDigits: 2
            });
        }

        // ✅ แก้ไขเงื่อนไขเช็ครหัสคูปองเป็น TATA10
        applyCouponBtn.addEventListener('click', function() {
            const code = couponCode.value.trim().toUpperCase();
            const selectedOption = productSelect.options[productSelect.selectedIndex];
            const price = (selectedOption && selectedOption.dataset.price) ? parseFloat(selectedOption.dataset.price) : 0;
            const qty = parseFloat(quantityInput.value) || 0;
            
            if (code === 'TATA10') {
                const subtotal = price * qty;
                if (subtotal > 0) {
                    const discountValue = subtotal * 0.10; // คำนวณลด 10%
                    discountInput.value = discountValue.toFixed(2);
                    couponStatus.innerText = "ใช้งานคูปองสำเร็จ! ลด 10%";
                    couponStatus.className = "form-text text-success";
                    calculateTotal();
                } else {
                    couponStatus.innerText = "กรุณาเลือกสินค้าและระบุจำนวนก่อน";
                    couponStatus.className = "form-text text-warning";
                }
            } else if (code === "") {
                couponStatus.innerText = "กรุณากรอกรหัสคูปอง";
                couponStatus.className = "form-text text-muted";
            } else {
                couponStatus.innerText = "รหัสคูปองไม่ถูกต้อง";
                couponStatus.className = "form-text text-danger";
            }
        });

        productSelect.addEventListener('change', calculateTotal);
        quantityInput.addEventListener('input', calculateTotal);
        discountInput.addEventListener('input', calculateTotal);
    });
</script>