<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/bootstrap.min.css">
    <link rel="stylesheet" href="/css/all.css">
    
    
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f4f7fe; }
        .stat-card { border: none; border-radius: 20px; transition: all 0.3s; }
        .stat-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.05); }
        .icon-box { width: 50px; height: 50px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 24px; }
        .bg-glass { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(10px); }
        .table-custom { border-radius: 15px; overflow: hidden; background: white; }
    </style>
</head>

<body>
    <%- include('navbar.ejs') %>

    <div class="container mt-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="font-weight-bold text-dark">ยินดีต้อนรับคุณ, <%= user.name %>! 👋</h2>
                <p class="text-muted">นี่คือภาพรวมธุรกิจของคุณในวันนี้</p>
            </div>
            <a href="/sales/new" class="btn btn-primary btn-lg shadow-sm rounded-pill px-4">
                <i class="fas fa-plus mr-2"></i>เริ่มการขายใหม่
            </a>
        </div>

        <div class="row">
            <div class="col-md-3 mb-4">
                <div class="card stat-card shadow-sm h-100">
                    <div class="card-body d-flex align-items-center">
                        <div class="icon-box bg-light-primary text-primary mr-3" style="background: #eef2ff;">
                            <i class="fas fa-wallet"></i>
                        </div>
                        <div>
                            <small class="text-muted d-block uppercase">รายได้รวม</small>
                            <h4 class="font-weight-bold mb-0">฿ <%= stats.revenue %></h4>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-4">
                <div class="card stat-card shadow-sm h-100">
                    <div class="card-body d-flex align-items-center">
                        <div class="icon-box text-success mr-3" style="background: #ecfdf5;">
                            <i class="fas fa-shopping-cart"></i>
                        </div>
                        <div>
                            <small class="text-muted d-block">จำนวนออเดอร์</small>
                            <h4 class="font-weight-bold mb-0"><%= stats.orders %> รายการ</h4>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-4">
                <div class="card stat-card shadow-sm h-100">
                    <div class="card-body d-flex align-items-center">
                        <div class="icon-box text-info mr-3" style="background: #e0f2fe;">
                            <i class="fas fa-box"></i>
                        </div>
                        <div>
                            <small class="text-muted d-block">สินค้าในระบบ</small>
                            <h4 class="font-weight-bold mb-0"><%= stats.products %> ชิ้น</h4>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3 mb-4">
                <div class="card stat-card shadow-sm h-100">
                    <div class="card-body d-flex align-items-center">
                        <div class="icon-box text-warning mr-3" style="background: #fffbeb;">
                            <i class="fas fa-users"></i>
                        </div>
                        <div>
                            <small class="text-muted d-block">สมาชิกทั้งหมด</small>
                            <h4 class="font-weight-bold mb-0"><%= stats.members %> คน</h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-12 mt-2">
                <div class="card shadow-sm table-custom border-0">
                    <div class="card-header bg-white py-3">
                        <h5 class="mb-0 font-weight-bold text-danger">
                            <i class="fas fa-exclamation-triangle mr-2"></i>สินค้าใกล้หมด (ควรสั่งเพิ่ม!)
                        </h5>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-hover mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th>ชื่อสินค้า</th>
                                    <th class="text-center">คงเหลือในสต็อก</th>
                                    <th class="text-right">จัดการ</th>
                                </tr>
                            </thead>
                          <tbody>
    <% if (stats.lowStock.length > 0) { %>
        <% stats.lowStock.forEach(p => { %>
            <tr class="<%= p.stock === 0 ? 'table-danger' : '' %>"> 
                <td class="align-middle font-weight-bold">
                    <%= p.name %>
                    <% if (p.stock === 0) { %>
                        <span class="badge badge-danger ml-2">OUT OF STOCK</span>
                    <% } %>
                </td>
                <td class="text-center align-middle">
                    <% if (p.stock === 0) { %>
                        <span class="badge badge-pill badge-dark py-2 px-3" style="background: #000;">
                            หมดเกลี้ยง! (0 ชิ้น)
                        </span>
                    <% } else { %>
                        <span class="badge badge-pill badge-danger py-2 px-3">
                            เหลือเพียง <%= p.stock %> ชิ้น
                        </span>
                    <% } %>
                </td>
                <td class="text-right">
                    <a href="/manage" class="btn btn-sm btn-primary rounded-pill px-3 shadow-sm">
                        <i class="fas fa-plus-circle mr-1"></i> เติมสต็อก
                    </a>
                </td>
            </tr>
        <% }) %>
    <% } else { %>
        <tr>
            <td colspan="3" class="text-center py-4 text-muted">🎉 ยอดเยี่ยม! สินค้าทุกอย่างยังมีสต็อกเพียงพอ</td>
        </tr>
    <% } %>
</tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="row mt-5 mb-5">
            <div class="col-md-12 text-center">
                <hr>
                <div class="btn-group shadow-sm">
                    <a href="/manage" class="btn btn-white bg-white px-4 py-3"><i class="fas fa-boxes mr-2"></i>สต็อกสินค้า</a>
                    <a href="/sales/report" class="btn btn-white bg-white px-4 py-3"><i class="fas fa-chart-line mr-2"></i>รายงานยอดขาย</a>
                    <a href="/members" class="btn btn-white bg-white px-4 py-3"><i class="fas fa-user-friends mr-2"></i>ข้อมูลสมาชิก</a>
                </div>
            </div>
        </div>
    </div>

    <script src="/js/jquery-3.4.1.slim.min.js"></script>
    <script src="/js/bootstrap.min.js"></script>
</body>

</html>